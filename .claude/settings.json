{
    "$schema": "https://json.schemastore.org/claude-code-settings.json",
    "hooks": {
        "SessionStart": [
            {
                "matcher": "startup|clear|compact",
                "hooks": [
                    {
                        "type": "command",
                        "command": "\"$HOME/.claude/plugins/superpowers/hooks/run-hook.cmd\" session-start",
                        "async": false
                    }
                ]
            }
        ]
    }
}
